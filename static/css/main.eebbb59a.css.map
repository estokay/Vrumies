.payouts-container {
  padding: 20px;
  background: #222;
  color: white;
  min-height: 100vh;
}

.orders-list {
  list-style: none;
  padding: 0;
  margin: 0;
  max-height: 60vh;
  overflow-y: auto;
}

.order-item {
  padding: 10px;
  border: 1px solid #444;
  border-radius: 5px;
  margin-bottom: 10px;
  cursor: pointer;
  transition: background 0.2s;
}

.order-item:hover {
  background: #333;
}

.order-item.selected {
  background: #007bff;
}

.payout-btn {
  margin-top: 20px;
  padding: 10px 20px;
  background: #28a745;
  color: white;
  border: none;
  border-radius: 5px;
  cursor: pointer;
  font-size: 16px;
}

.payout-btn:hover {
  background: #218838;
}

.loading {
  color: white;
}

.error {
  color: red;
}