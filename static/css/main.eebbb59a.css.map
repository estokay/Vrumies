.pm-container {
  padding: 20px;
  background: #222;
  color: white;
  min-height: 100vh;
}

.pm-section {
  margin-bottom: 30px;
  padding: 15px;
  border: 1px solid #444;
  border-radius: 8px;
  background: #2a2a2a;
}

.pm-toggle {
  display: flex;
  gap: 10px;
  margin-top: 10px;
}

.pm-toggle button {
  padding: 10px 20px;
  border: none;
  border-radius: 5px;
  cursor: pointer;
  background: #555;
  color: white;
  transition: 0.2s;
}

.pm-toggle button:hover {
  background: #777;
}

.pm-toggle button.active {
  background: #007bff;
}

.pm-loading {
  color: white;
}